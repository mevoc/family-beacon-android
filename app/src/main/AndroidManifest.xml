<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- SMS -->
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.SEND_SMS" />

    <!-- Location -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- Foreground services (panic + ev location) -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Android 10+ om du kör location i foreground service senare -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Panic -->
    <uses-permission android:name="android.permission.FLASHLIGHT" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS" />

    <!-- Biometric prompt -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Background location required for geofencing on Android 10+ -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <!-- Required for foreground service with mediaPlayback type on Android 14+ -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FamilyBeacon">
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.FamilyBeacon">
        </activity>
        <activity
            android:name=".ui.ConsentActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ui.EventsActivity"
            android:exported="false" />
        <activity
            android:name=".ui.WhitelistActivity"
            android:exported="false" />

        <!-- SMS receiver -->
        <receiver
            android:name=".receiver.SmsReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Geofence transition receiver -->
        <receiver
            android:name=".receiver.GeofenceReceiver"
            android:exported="false" />

        <!-- Panic foreground service -->
        <service
            android:name=".service.PanicService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- (För senare) Location foreground service -->
        <service
            android:name=".service.LocationFgService"
            android:exported="false"
            android:foregroundServiceType="location" />

    </application>

</manifest>